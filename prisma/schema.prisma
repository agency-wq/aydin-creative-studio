// Aydin Creative Studio - Database schema
// Single-tenant: solo team Aydin, ma con workspace separati per cliente.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// CLIENT WORKSPACE
// =====================================================================

model Client {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  logoUrl     String?
  brandColors Json?    // BrandKit estratto da Claude Vision dal mockup
  brandFonts  Json?    // Font style info estratta dal mockup

  // Mockup prodotto (copertine guide, lead magnet, ecc.)
  // Path relativi a public/ (usabili con staticFile() in Remotion)
  mockupUrls  String[] @default([])
  // Nome del prodotto estratto dal mockup (es. "Guida alla Libertà Finanziaria")
  productName String?

  // Preferenze video di default per questo cliente
  defaultAvatarId        String?
  defaultVoiceProvider   String? // "heygen" | "elevenlabs"
  defaultVoiceId         String?
  defaultCaptionPresetId String?
  defaultMotionPresetId  String?

  // Sottoinsieme di avatar/voci preferiti per questo cliente
  preferredAvatarIds String[] @default([])
  preferredVoiceIds  String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects     Project[]
  avatarUsages AvatarUsage[]

  @@index([slug])
}

// =====================================================================
// PROJECT (un singolo video da generare)
// =====================================================================

model Project {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title  String
  script String  @db.Text
  notes  String?

  // Configurazione di generazione (snapshot al momento del create)
  avatarId      String // HeyGen avatar look id
  voiceProvider String // "heygen" | "elevenlabs"
  voiceId       String // voice id del provider scelto

  // Se voiceProvider == "elevenlabs", possiamo override le settings di voice
  elevenlabsSettings Json? // { stability, similarity_boost, style, use_speaker_boost }

  captionPresetId String?
  motionPresetId  String?
  musicMood       String?

  resolution  String @default("720p")
  aspectRatio String @default("9:16")

  // Stato + asset
  status        ProjectStatus @default(DRAFT)
  finalVideoUrl String?
  thumbnailUrl  String?

  // Trascrizione AssemblyAI con word-level timestamps
  // { text, words: [{ word, start, end, confidence }], language }
  transcript Json?

  // Clip motion graphics generate via fal.ai (URL temporanei firmati)
  motionGraphicsClips MotionGraphicsClip[]

  // Clip b-roll salvate (Pexels stock o fal.ai generate)
  brollClips BrollClip[]

  // Costi
  costEstimate Float?
  costActual   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  renderJobs RenderJob[]

  @@index([clientId, createdAt])
  @@index([status])
}

enum ProjectStatus {
  DRAFT
  QUEUED
  GENERATING_AUDIO
  GENERATING_AVATAR
  TRANSCRIBING
  GENERATING_MOTION_GRAPHICS
  GENERATING_BROLL
  GENERATING_MUSIC
  RENDERING
  COMPLETED
  FAILED
}

// =====================================================================
// RENDER JOB (tracking BullMQ + step-by-step)
// =====================================================================

model RenderJob {
  id        String @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  bullJobId String?
  step      String
  attempt   Int @default(1)

  // External references
  heygenAudioAssetId     String?
  heygenVideoId          String?
  heygenAvatarUrl        String?
  elevenlabsAudioPath    String?
  assemblyaiTranscriptId String?
  motionGraphicsClipUrls String[] @default([])
  brollUrls              String[] @default([])
  musicUrl               String?

  // Output finale
  finalRenderPath String?

  status       JobStatus @default(PENDING)
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// =====================================================================
// AVATAR LIBRARY (snapshot della libreria HeyGen curata)
// =====================================================================

model Avatar {
  id               String   @id // = HeyGen avatar look id
  name             String
  firstName        String
  gender           String // "male" | "female"
  aspect           String // "9:16" | "16:9" | "1:1"
  width            Int
  height           Int
  avatarType       String // "photo_avatar" | "video_avatar" | "studio_avatar"
  supportedEngines String[] @default([])
  defaultVoiceId   String?
  previewImageUrl  String?
  previewVideoUrl  String?
  groupId          String?

  // Filtri smart per UI
  // hasLatinName: il nome inizia con un carattere latino (esclude russo/cinese/arabo)
  hasLatinName Boolean @default(false)
  // hasPreview: c'e un thumbnail effettivamente visibile
  hasPreview Boolean @default(false)

  // Tagging custom per filtri UI. Popolato dal backfill con i tags
  // ritornati da GET /v2/avatar/{id}/details (es. ["AVATAR_IV"], ["AVATAR_III"]).
  tags String[] @default([])

  // Quality tier derivato dai tags:
  //   "premium"  = AVATAR_IV (lip sync perfetto, fotorealismo top, ~6x costo)
  //   "standard" = AVATAR_III (lip sync molto buono, fotorealismo buono)
  //   "legacy"   = AVATAR_II o no-tag o talking_photo (lip sync pupazzoso)
  quality String @default("standard")

  // Rating manuale dall'utente dopo aver testato l'avatar in un render reale.
  // 0 = mai testato, 1-5 = valutazione (5 = perfetto per italiano + ElevenLabs)
  rating Int @default(0)

  // Timestamp dell'ultimo test effettuato su questo avatar (per capire se
  // la review e' ancora valida dopo un nuovo training/upgrade HeyGen).
  lastTestedAt DateTime?

  // Marcato come preferito dall'utente (appare in cima alla griglia)
  favorite Boolean @default(false)

  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usages AvatarUsage[]

  @@index([gender, aspect])
  @@index([hasLatinName, hasPreview, enabled])
  @@index([quality, rating])
}

// Tracciamento usi per rotazione (mai stesso avatar 2 volte di fila per cliente)
model AvatarUsage {
  id       String @id @default(cuid())
  avatarId String
  avatar   Avatar @relation(fields: [avatarId], references: [id])
  clientId String
  client   Client @relation(fields: [clientId], references: [id])
  usedAt   DateTime @default(now())

  @@index([clientId, usedAt])
  @@index([avatarId])
}

// =====================================================================
// VOICE LIBRARY (voci ElevenLabs + HeyGen italiane)
// L'utente puo scegliere tra le due provider nella UI del nuovo video
// =====================================================================

model Voice {
  id         String  @id // voice id provider
  provider   String // "elevenlabs" | "heygen"
  name       String
  language   String  @default("it")
  gender     String? // "male" | "female"
  category   String? // "premade" | "professional" | "cloned"
  useCase    String? // "advertisement" | "narrative_story" | "informative_educational"
  ageRange   String? // "young" | "middle_aged" | "old"
  previewUrl String?

  // Per ElevenLabs: settings consigliate per questa voce
  recommendedSettings Json? // { stability, similarity_boost, style, use_speaker_boost }

  // Marcato come preferito dall'utente
  favorite Boolean @default(false)

  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, id])
  @@index([provider, language])
  @@index([favorite])
}

// =====================================================================
// PRESETS: CAPTIONS + MOTION GRAPHICS
// =====================================================================

model CaptionsPreset {
  id           String  @id @default(cuid())
  name         String  @unique
  description  String?
  thumbnailUrl String?

  remotionComponent String
  defaultProps      Json

  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Clip generata da fal.ai (modello configurabile) per un singolo project.
// Un Project puo averne piu di una (es. 4-6 cutaway che cambiano stile).
model MotionGraphicsClip {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  presetId  String? // riferimento al preset usato (opzionale, soft-link)
  presetName String?

  prompt     String  @db.Text
  videoUrl   String  @default("") // legacy, vuoto per i clip Remotion-based
  thumbnailUrl String?
  durationSec Int?
  requestId  String? // fal.ai request_id (per debug / re-fetch, legacy)
  seed       Int?

  // Modello fal.ai usato + costo stimato (legacy)
  model        String?
  costUsd      Float?

  // ===========================================================================
  // Remotion motion graphics templates (NUOVO approccio post-fix)
  // Le motion graphics ora sono renderizzate inline da Remotion (no fal.ai).
  // - templateName: id del template registrato in src/remotion/motion-graphics/registry
  // - templateProps: i props passati al template (es. { text, number, items, ... })
  // - themeName: nome del theme (palette + font) per styling
  // ===========================================================================
  templateName  String?
  templateProps Json?
  themeName     String?

  // Status: PENDING -> RUNNING -> COMPLETED | FAILED
  status   String @default("PENDING")
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

// B-roll clip salvata per un project. Source = "pexels" | "falai".
model BrollClip {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  source     String // "pexels" | "falai"
  externalId String? // pexels video id, fal request id, ecc.
  query      String? // keyword di ricerca usata

  videoUrl     String
  thumbnailUrl String?
  width        Int?
  height       Int?
  durationSec  Int?

  // Attribuzione (Pexels richiede credit a creator)
  authorName String?
  authorUrl  String?
  pageUrl    String?

  // Posizionamento nel timeline finale (deciso in editor)
  orderIndex Int     @default(0)
  startMs    Int?
  endMs      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model MotionGraphicsPreset {
  id               String  @id @default(cuid())
  name             String  @unique
  description      String?
  thumbnailUrl     String?
  creatorAvatarUrl String?

  prompt            String   @db.Text
  styleReferenceUrl String?
  cachedFrameUrls   String[] @default([])
  model             String   @default("veo-3.1-fast")
  provider          String   @default("fal.ai")
  defaultDuration   Int      @default(5)
  qualityTier       String   @default("fast")

  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
