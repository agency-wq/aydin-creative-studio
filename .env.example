# =============================================================================
# Aydin Creative Studio - WebApp .env
# Copia in .env e riempi con le tue chiavi.
# NON committare il file .env con le chiavi reali!
# =============================================================================

# DATABASE (Postgres — Railway in prod, localhost in dev)
DATABASE_URL="postgresql://user:password@localhost:5432/aydin_creative_dev?schema=public"

# REDIS (per BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# HEYGEN (avatar video — https://app.heygen.com/settings/api)
HEYGEN_API_KEY=

# ELEVENLABS (TTS + musica — https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=

# ASSEMBLYAI (trascrizione word-level — https://www.assemblyai.com/app/account)
ASSEMBLYAI_API_KEY=

# fal.ai (Veo 3.1 per motion graphics AI — https://fal.ai/dashboard/keys)
FAL_KEY=

# PEXELS (b-roll stock gratis — https://www.pexels.com/api/new/)
PEXELS_API_KEY=

# ANTHROPIC (Claude per script generator + AI Director — https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# AUTH (NextAuth — genera con: openssl rand -base64 32)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
# TEAM_PASSWORD=
